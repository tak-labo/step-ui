# step-ca接続情報
DOCKER_STEPCA_INIT_NAME=Step CA
CA_URL=https://step-ca:9000
CA_FINGERPRINT=your_root_ca_fingerprint_here
CA_PROVISIONER=admin

# 本番で nginx を使う場合の公開ドメイン / URL
# PUBLIC_URL が未設定なら https://PUBLIC_DOMAIN を使う
PUBLIC_DOMAIN=localhost
PUBLIC_URL=https://localhost
NGINX_ENABLED=false

# NextAuth
NEXTAUTH_SECRET=your_random_secret_here
NEXTAUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true

# UIログイン（bcrypt hash）
UI_USERNAME=admin
# bcrypt hash を Base64 エンコードした値を設定する（$をDocker Composeが変数展開するのを防ぐ）
# 生成方法: node -e "const b=require('bcryptjs'); b.hash('パスワード',10).then(h=>console.log(Buffer.from(h).toString('base64')))"
UI_PASSWORD_HASH=your_bcrypt_hash_base64_here

# フロントエンドからACMEエンドポイントURLを構成するために使用
NEXT_PUBLIC_CA_URL=https://step-ca:9000

# step-caの初期化パスワード（step-ui の CA_PROVISIONER_PASSWORD もこれを使う）
DOCKER_STEPCA_INIT_PASSWORD=your_stepca_password_here

# step-ca接続情報
CA_URL=https://step-ca:9000
CA_FINGERPRINT=your_root_ca_fingerprint_here
CA_PROVISIONER=admin
CA_PROVISIONER_PASSWORD=your_provisioner_password_here

# NextAuth
NEXTAUTH_SECRET=your_random_secret_here
NEXTAUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true

# UIログイン（bcryptハッシュ）
UI_USERNAME=admin
# bcryptハッシュをBase64エンコードした値を設定する（$をDocker Composeが変数展開するのを防ぐ）
# 生成方法: node -e "const b=require('bcryptjs'); b.hash('パスワード',10).then(h=>console.log(Buffer.from(h).toString('base64')))"
UI_PASSWORD_HASH=your_bcrypt_hash_base64_here

# フロントエンドからACMEエンドポイントURLを構成するために使用
NEXT_PUBLIC_CA_URL=https://step-ca:9000

# step-caの初期化パスワード（docker-compose.yml参照）
STEPCA_PASSWORD=your_stepca_password_here
